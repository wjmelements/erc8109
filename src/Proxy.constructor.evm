// Constructor: delegates[configure(bytes4,address).selector] = new Bootstrap(owner=msg.sender)

// set up delegatecall
0 0 68 0

MSTORE(0, OR(SHL(160, 0x605d8060093d393df373), CALLER))
CODECOPY(32, constructbootstrapsuffix, #constructbootstrapsuffix)
CREATE(0, 2, 175)

// configure(bytes4,address).selector
MSTORE(4, SHL(224, 0x0ee62dbe))
MSTORE(36, DUP1)

GAS DELEGATECALL

#proxy
CODECOPY(0, proxy, DUP1) // TODO: compare to two MSTORE
0 RETURN
{
    constructbootstrapsuffix: 0x3314602857638e4a23d65f5233595258601cfd5b602435600435805f528160405f20557f7c86091fe23e473af4b780c37525ce8cfa74ec05a4a4e7d4d3e7f0551d86a7ce5f5fa3,
    proxy: assemble src/Proxy.evm
}
